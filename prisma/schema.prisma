
generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String?
  endereco  String?
  role      String   @default("user")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chats     Chat[]
  agendamentos Agendamento[]
  postagens Postagem[]
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  telefone  String?
  endereco  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Especialista {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  telefone  String?
  endereco  String?
  formacao  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Servico {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chat {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

}

model Agendamento {
  id        Int      @id @default(autoincrement())
  userId    Int
  data      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Postagem {
  id        Int      @id @default(autoincrement())
  userId    Int
  titulo    String
  conteudo  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

