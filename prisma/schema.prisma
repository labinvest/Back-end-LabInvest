
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String?
  endereco  String?
  role      String   @default("user")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  chats              Chat[]
  chatsEspecialista  Chat[]              @relation("ChatEspecialista")
  agendamentos       Agendamento[]
  agendamentosEspec  Agendamento[]       @relation("AgendamentoEspecialista")
  postagens          Postagem[]
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  telefone  String?
  endereco  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Especialista {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  telefone  String?
  endereco  String?
  formacao  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Servico {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  agendamentos Agendamento[]
}

model Chat {
  id              Int      @id @default(autoincrement())
  userId          Int
  especialistaId  Int?
  assunto         String
  mensagem        String
  status          String   @default("aberto")  // aberto, respondido, fechado
  prioridade      String   @default("normal")  // baixa, normal, alta
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User  @relation(fields: [userId], references: [id])
  especialista   User? @relation("ChatEspecialista", fields: [especialistaId], references: [id])

  @@index([userId])
  @@index([especialistaId])
}

model Agendamento {
  id              Int      @id @default(autoincrement())
  userId          Int
  especialistaId  Int?
  servicoId       Int?
  titulo          String
  descricao       String?
  dataInicio      DateTime
  dataFim         DateTime?
  duracao         Int?     // em minutos
  status          String   @default("agendado")  // agendado, confirmado, realizado, cancelado
  local           String?
  notas           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User      @relation(fields: [userId], references: [id])
  especialista   User?     @relation("AgendamentoEspecialista", fields: [especialistaId], references: [id])
  servico        Servico?  @relation(fields: [servicoId], references: [id])

  @@index([userId])
  @@index([especialistaId])
  @@index([servicoId])
}

model Postagem {
  id        Int      @id @default(autoincrement())
  userId    Int
  titulo    String
  conteudo  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

